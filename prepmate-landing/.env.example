# Frontend API base URL (must include /api)
REACT_APP_API_BASE_URL=http://localhost:5000/api

# Optional legacy key supported for backward compatibility
# REACT_APP_API_URL=http://localhost:5000/api

# Existing app keys (use your own values)
REACT_APP_GEMINI_API_KEY=your_gemini_api_key
REACT_APP_GEMINI_MODEL=gemini-2.5-flash-preview-native-audio-dialog

# Optional Cloudinary settings
REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
